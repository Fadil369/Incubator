{
  "name": "brainsait-backend",
  "version": "1.0.0",
  "description": "BrainSAIT Platform Backend API - Healthcare SME Services",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:seed": "ts-node src/database/seeders/index.ts",
    "clean": "rm -rf dist node_modules",
    "deploy:backend": "npm run build && wrangler deploy",
    "preview:backend": "npm run build && wrangler deploy --env preview"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.60.0",
    "@cloudflare/workers-types": "^4.20250830.0",
    "@prisma/client": "^5.22.0",
    "@types/validator": "^13.15.2",
    "bcryptjs": "^2.4.3",
    "brainsait-shared": "file:../brainsait-shared",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.2.1",
    "helmet": "^7.2.0",
    "hono": "^4.9.5",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.4",
    "openai": "^5.16.0",
    "puppeteer": "^24.17.1",
    "qrcode": "^1.5.4",
    "redis": "^4.7.1",
    "validator": "^13.15.15",
    "winston": "^3.17.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.19.11",
    "@types/nodemailer": "^6.4.19",
    "@types/puppeteer": "^5.4.7",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "prisma": "^5.22.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
